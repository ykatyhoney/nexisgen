NEXIS_NETUID=70
NEXIS_LOG_LEVEL=INFO
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=~/.bittensor/wallets

# Hippius S3 storage
HIPPIUS_S3_ENDPOINT=https://s3.hippius.com
HIPPIUS_S3_REGION=decentralized

# Miner required
HIPPIUS_BUCKET=
HIPPIUS_READ_ACCESS_KEY=
HIPPIUS_READ_SECRET_KEY=
HIPPIUS_WRITE_ACCESS_KEY=
HIPPIUS_WRITE_SECRET_KEY=

# Miner pipeline
NEXIS_SOURCES_FILE=sources.txt
NEXIS_WORKDIR=.nexis
NEXIS_BLOCK_POLL_SEC=6
TARGET_RESOLUTION=720
NEXIS_VALIDATOR_BLACKLIST_FILE=validator_blacklist_hotkeys.txt

# LLM provider keys (OpenAI preferred when both are set)
OPENAI_API_KEY=
GEMINI_API_KEY=
NEXIS_CAPTION_MODEL=gpt-4o
NEXIS_CAPTION_TIMEOUT_SEC=30
NEXIS_VALIDATOR_SEMANTIC_CHECK_ENABLED=true
NEXIS_VALIDATOR_SEMANTIC_MODEL=gpt-4o
NEXIS_VALIDATOR_SEMANTIC_TIMEOUT_SEC=20
NEXIS_VALIDATOR_SEMANTIC_MAX_SAMPLES=8
NEXIS_VALIDATOR_SOURCE_AUTH_ENABLED=true

# Validator required
NEXIS_RECORD_INFO_BUCKET=nexis-record-info
NEXIS_RECORD_INFO_READ_ACCESS_KEY=hip_a1369c744c0b5a8990004dd1
NEXIS_RECORD_INFO_READ_SECRET_KEY=4sr4eOucZHOZfa6XsOAPvWfU7HaXCKIfOhGwe8aRKZQ
NEXIS_RECORD_INFO_OBJECT_KEY=record_info.json
NEXIS_VALIDATION_API_URL=
NEXIS_VALIDATION_API_TIMEOUT_SEC=10

# Owner requred
NEXIS_OWNER_VALIDATOR_HOTKEY=5EJGfSvRcEGVQtqDuU7YYwuZRHmaktf6JEZDeFPyeXksiHrm
NEXIS_OWNER_DB_BUCKET=nexis-dataset
NEXIS_OWNER_DB_READ_ACCESS_KEY=
NEXIS_OWNER_DB_READ_SECRET_KEY=
NEXIS_OWNER_DB_WRITE_ACCESS_KEY=
NEXIS_OWNER_DB_WRITE_SECRET_KEY=
NEXIS_RECORD_INFO_WRITE_ACCESS_KEY=
NEXIS_RECORD_INFO_WRITE_SECRET_KEY=
