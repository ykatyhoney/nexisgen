# ---------------------------------------------------
# Docker Compose interpolation vars (host-side)
# ---------------------------------------------------
# Use this file with:
# docker compose --env-file validation-api.env -f docker-compose.validation-api.yml up -d --build
POSTGRES_DB=nexis_validation
POSTGRES_USER=nexis
POSTGRES_PASSWORD=nexis
POSTGRES_HOST_PORT=5432
VALIDATION_API_PORT=8080
NEXIS_VALIDATION_PGDATA=./data/postgres
VALIDATION_API_ENV_FILE=./validation-api.env

# ---------------------------------------------------
# Validation API app vars (container-side)
# ---------------------------------------------------
# Subnet connection settings used for validator allowlist sync
NEXIS_NETUID=70
BT_NETWORK=finney

# Bittensor wallet used for chain reads (no signing required for API)
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=/root/.bittensor/wallets

# Postgres DSN is injected by docker-compose.validation-api.yml
# NEXIS_VALIDATION_API_POSTGRES_DSN=postgresql://nexis:nexis@postgres:5432/nexis_validation

# Auth + allowlist policy
NEXIS_VALIDATION_API_MIN_VALIDATOR_STAKE=5000
NEXIS_VALIDATION_API_ALLOWLIST_REFRESH_SEC=300
NEXIS_VALIDATION_API_AUTH_MAX_SKEW_SEC=300
NEXIS_VALIDATION_API_NONCE_MAX_AGE_SEC=86400

# Optional logging
NEXIS_LOG_LEVEL=INFO

