# -------------------------------
# Required validator runtime vars
# -------------------------------
NEXIS_NETUID=70
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=/root/.bittensor/wallets
R2_ACCOUNT_ID=
R2_REGION=auto
NEXIS_BLOCK_POLL_SEC=6
NEXIS_DATASET_CATEGORY=nature_landscape_scenery
NEXIS_WORKDIR=/var/lib/nexis

# -------------------------------
# Recommended validator controls
# -------------------------------
NEXIS_LOG_LEVEL=INFO
NEXIS_VALIDATOR_ENABLED_SPECS=video_v1
NEXIS_VALIDATOR_SEMANTIC_CHECK_ENABLED=true
NEXIS_VALIDATOR_SEMANTIC_MODEL=gpt-4o
NEXIS_VALIDATOR_SEMANTIC_TIMEOUT_SEC=20
NEXIS_VALIDATOR_SEMANTIC_MAX_SAMPLES=8
NEXIS_VALIDATOR_CATEGORY_CHECK_ENABLED=true
NEXIS_VALIDATOR_CATEGORY_MODEL=gpt-4o
NEXIS_VALIDATOR_CATEGORY_TIMEOUT_SEC=20
NEXIS_VALIDATOR_CATEGORY_MAX_SAMPLES=8

NEXIS_RECORD_INFO_BUCKET=nexis-record-info
NEXIS_RECORD_INFO_ACCOUNT_ID=
NEXIS_RECORD_INFO_READ_ACCESS_KEY=
NEXIS_RECORD_INFO_READ_SECRET_KEY=
NEXIS_RECORD_INFO_OBJECT_KEY=record_info.json

OPENAI_API_KEY=
GEMINI_API_KEY=
NEXIS_VALIDATION_API_URL=https://api.nexisgen.ai/v1/validation-results
NEXIS_VALIDATION_API_TIMEOUT_SEC=10

# -------------------------------
# Optional owner-validator vars
# -------------------------------
NEXIS_OWNER_VALIDATOR_HOTKEY=5EJGfSvRcEGVQtqDuU7YYwuZRHmaktf6JEZDeFPyeXksiHrm
NEXIS_OWNER_DB_BUCKET=nexis-dataset
NEXIS_OWNER_DB_ACCOUNT_ID=
NEXIS_OWNER_DB_READ_ACCESS_KEY=
NEXIS_OWNER_DB_READ_SECRET_KEY=
NEXIS_OWNER_DB_WRITE_ACCESS_KEY=
NEXIS_OWNER_DB_WRITE_SECRET_KEY=
NEXIS_RECORD_INFO_WRITE_ACCESS_KEY=
NEXIS_RECORD_INFO_WRITE_SECRET_KEY=
