# Host paths and deployment channel for docker-compose.validator.yml

# Required host mount for bittensor wallet files.
BT_WALLET_HOST_PATH=~/.bittensor/wallets

# Optional host override paths.
NEXIS_WORKDIR_HOST_PATH=./data/nexis
VALIDATOR_BLACKLIST_HOST_PATH=../validator_blacklist_hotkeys.txt

# Validator image channel watched by watchtower.
# Keep this on :latest for fully automatic updates.
NEXIS_VALIDATOR_IMAGE=rendixnetwork/nexis:latest

# Auto-update polling interval in seconds.
WATCHTOWER_POLL_INTERVAL=300

# App env file consumed by the validator container.
VALIDATOR_ENV_FILE=./validator.env

# Optional Grafana/Loki ports
LOKI_PORT=3100
GRAFANA_PORT=3000
